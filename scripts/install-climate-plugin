#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$SCRIPT_DIR/install_climate_plugin.py" "$@"
fi

if command -v python >/dev/null 2>&1; then
  exec python "$SCRIPT_DIR/install_climate_plugin.py" "$@"
fi

echo "Climate requires Python 3.10 or newer. Install Python 3 and try again." >&2
exit 1
